#!/usr/bin/env python3
"""List or delete Claude Code sessions for the current (or given) directory."""

import argparse
import json
import shutil
import sys
from pathlib import Path


def project_dir(target: Path) -> Path:
    return Path.home() / '.claude' / 'projects' / str(target).replace('/', '-')


def list_sessions(proj_dir: Path, target: Path):
    sessions = []
    for jsonl in sorted(proj_dir.glob('*.jsonl')):
        title = None
        with jsonl.open() as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if obj.get('type') == 'ai-title':
                    title = obj.get('aiTitle', '')
                    break
        sessions.append((jsonl.stem, title or '(no title)'))

    if not sessions:
        print(f"No sessions in: {proj_dir}", file=sys.stderr)
        sys.exit(1)

    print(f"Claude sessions for: {target}\n")
    for sid, title in sessions:
        print(f"  {sid}  {title}")


def delete_session(proj_dir: Path, session_id: str):
    jsonl = proj_dir / f"{session_id}.jsonl"
    if not jsonl.exists():
        print(f"Session {session_id} not found in {proj_dir}", file=sys.stderr)
        sys.exit(1)

    deleted = []

    jsonl.unlink()
    deleted.append(str(jsonl))

    for subdir in ('file-history', 'session-env'):
        path = Path.home() / '.claude' / subdir / session_id
        if path.exists():
            shutil.rmtree(path)
            deleted.append(str(path))

    for path in deleted:
        print(f"deleted {path}")


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument('dir', nargs='?', help='project directory (default: cwd)')
    parser.add_argument('-d', '--delete', metavar='SESSION_ID', help='delete a session by ID')
    args = parser.parse_args()

    target = Path(args.dir).resolve() if args.dir else Path.cwd()
    proj_dir = project_dir(target)

    if not proj_dir.exists():
        print(f"No Claude sessions found for: {target}", file=sys.stderr)
        sys.exit(1)

    if args.delete:
        delete_session(proj_dir, args.delete)
    else:
        list_sessions(proj_dir, target)


if __name__ == '__main__':
    main()
