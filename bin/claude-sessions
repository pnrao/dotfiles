#!/usr/bin/env python3
"""List Claude Code sessions for the current (or given) directory."""

import json
import os
import sys
from pathlib import Path

def main():
    target = Path(sys.argv[1]).resolve() if len(sys.argv) > 1 else Path.cwd()
    project_key = str(target).replace('/', '-')
    project_dir = Path.home() / '.claude' / 'projects' / project_key

    if not project_dir.exists():
        print(f"No Claude sessions found for: {target}", file=sys.stderr)
        sys.exit(1)

    sessions = []
    for jsonl in sorted(project_dir.glob('*.jsonl')):
        session_id = jsonl.stem
        title = None
        with jsonl.open() as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if obj.get('type') == 'ai-title':
                    title = obj.get('aiTitle', '')
                    break
        sessions.append((session_id, title or '(no title)'))

    if not sessions:
        print(f"No sessions in: {project_dir}", file=sys.stderr)
        sys.exit(1)

    print(f"Claude sessions for: {target}\n")
    for sid, title in sessions:
        print(f"  {sid}  {title}")

if __name__ == '__main__':
    main()
