import pprint
import sys

orig_displayhook = sys.displayhook

def mdir(a=None):
    if a is not None:
        return [x + '()' if callable(getattr(a, x)) else x + '*' for x in dir(a)]
    return [x + '()' if callable(x) else x + '*' for x in dir()]

def myhook(value):
    if value is not None:
        __builtins__._ = value
        pprint.pprint(value)

__builtins__.pprint_on = lambda: setattr(sys, 'displayhook', myhook)
__builtins__.pprint_off = lambda: setattr(sys, 'displayhook', orig_displayhook)
